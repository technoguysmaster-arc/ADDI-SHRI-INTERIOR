# Environment variables for AADI SHRI INTERIOR backend
# Copy this file to .env and fill in your values

SECRET_KEY=django-insecure-replace-this-with-a-strong-random-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL Database
DB_NAME=aadi_shri_interior
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Media / Static
MEDIA_URL=/media/
STATIC_URL=/static/

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

